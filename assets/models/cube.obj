# Wavefront OBJ — Simple cube for testing SceneViewer3D
# 8 vertices, 6 faces (2 triangles each = 12 triangles total)
# Exported with triangulated faces and vertex normals.

mtllib cube.mtl

# vertices
v  0.5  0.5  0.5
v -0.5  0.5  0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5

# cordenadas das texturas
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# normais
vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0

# faces
# Format: f v/vt/vn

# face frontal
usemtl Cube
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1

# face traseira
f 5/2/2 7/3/2 6/4/2
f 5/2/2 8/1/2 7/3/2

# face esquerda
f 2/1/3 6/2/3 7/3/3
f 2/1/3 7/3/3 3/4/3

# face direita
f 1/1/4 4/2/4 8/3/4
f 1/1/4 8/3/4 5/4/4

# face do topo
f 1/1/5 5/2/5 6/3/5
f 1/1/5 6/3/5 2/4/5

# face de baixo
f 4/1/6 3/2/6 7/3/6
f 4/1/6 7/3/6 8/4/6
