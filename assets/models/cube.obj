# Wavefront OBJ — Simple cube for testing SceneViewer3D
# 8 vertices, 6 faces (2 triangles each = 12 triangles total)
# Exported with triangulated faces and vertex normals.

mtllib cube.mtl

# ---- Vertices ----
v  0.5  0.5  0.5
v -0.5  0.5  0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5

# ---- Texture coordinates ----
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# ---- Normals (one per face direction) ----
vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0

# ---- Faces ----
# Format: f v/vt/vn

# Front face (+Z)
usemtl Cube
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1

# Back face (-Z)
f 5/2/2 7/3/2 6/4/2
f 5/2/2 8/1/2 7/3/2

# Left face (-X)
f 2/1/3 6/2/3 7/3/3
f 2/1/3 7/3/3 3/4/3

# Right face (+X)
f 1/1/4 4/2/4 8/3/4
f 1/1/4 8/3/4 5/4/4

# Top face (+Y)
f 1/1/5 5/2/5 6/3/5
f 1/1/5 6/3/5 2/4/5

# Bottom face (-Y)
f 4/1/6 3/2/6 7/3/6
f 4/1/6 7/3/6 8/4/6
